# ANIDB Environment Configuration
# Copy to .env and fill in values: cp .env.example .env

# === Required ===
ANTHROPIC_API_KEY=             # Your Anthropic API key (used by semantic engine)

# === Infrastructure ===
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=anidb_dev

EVENTSTORE_URI=esdb://localhost:2113?tls=false

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=anidb
POSTGRES_PASSWORD=anidb_dev
POSTGRES_DB=anidb
DATABASE_URL=postgresql://anidb:anidb_dev@localhost:5432/anidb

REDIS_URI=redis://localhost:6379

DUCKDB_PATH=./data/analytics.duckdb

# === Service Ports ===
API_PORT=3000
SEMANTIC_ENGINE_PORT=8001
ONTOLOGY_SERVICE_PORT=8002

# === Logging ===
LOG_LEVEL=info                 # debug | info | warn | error
RUST_LOG=info                  # Rust-specific log filter

# === Ontology ===
ONTOLOGY_VERSION=1             # Increment on breaking ontology changes
