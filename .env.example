# ANIDB Environment Configuration
# Copy to .env and fill in values: cp .env.example .env

# === Infrastructure ===
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=anidb_dev

EVENTSTORE_URI=esdb://localhost:2113?tls=false

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=anidb
POSTGRES_PASSWORD=anidb_dev
POSTGRES_DB=anidb
DATABASE_URL=postgresql://anidb:anidb_dev@localhost:5432/anidb

REDIS_URI=redis://localhost:6379

DUCKDB_PATH=./data/analytics.duckdb

# === Semantic Engine ===
# LLM provider selection: "anthropic" (default) or "openai"
LLM_PROVIDER=anthropic

# Anthropic config (required when LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=             # Your Anthropic API key
ANTHROPIC_MODEL=claude-sonnet-4-6

# OpenAI config (required when LLM_PROVIDER=openai)
# OPENAI_API_KEY=              # Your OpenAI API key
# OPENAI_MODEL=gpt-4o

EVENT_LOG_URL=http://localhost:8010
CONFIDENCE_STORE_URL=http://localhost:8003

# === Service Ports ===
API_PORT=3000
SEMANTIC_ENGINE_PORT=8001
ONTOLOGY_SERVICE_PORT=8002
CONFIDENCE_STORE_PORT=8003
EVENT_LOG_PORT=8010

# === Logging ===
LOG_LEVEL=info                 # debug | info | warn | error
RUST_LOG=info                  # Rust-specific log filter

# === Ontology ===
ONTOLOGY_VERSION=1             # Increment on breaking ontology changes
